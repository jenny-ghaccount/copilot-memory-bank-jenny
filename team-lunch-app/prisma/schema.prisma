// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  emailVerified DateTime? // Required for NextAuth email provider
  dietaryTags  String?   // Comma-separated list for SQLite
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // NextAuth relations
  accounts     Account[]
  sessions     Session[]

  // Relations
  teamMembers  TeamMember[]
  pollVotes    PollVote[]
  suggestions  PollSuggestion[]
  reviews      Review[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Team {
  id           String                        @id @default(cuid())
  name         String
  meetingPoint String?  // Store as "lat,lng" format for SQLite
  settings     String?   // JSON as string for SQLite                         
  createdAt    DateTime                      @default(now())
  updatedAt    DateTime                      @updatedAt

  // Relations
  members         TeamMember[]
  polls           Poll[]
  teamRestaurants TeamRestaurant[]

  @@map("teams")
}

model TeamMember {
  teamId    String
  userId    String
  role      String @default("MEMBER")  // ORGANIZER or MEMBER
  joinedAt  DateTime   @default(now())

  // Relations
  team      Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@map("team_members")
}

model Restaurant {
  id          String                        @id @default(cuid())
  provider    String                        // 'overpass', 'manual', etc.
  providerId  String?                       // External ID from provider
  name        String
  location    String?   // Store as "lat,lng" format for SQLite
  cuisineTags String?   // Comma-separated list for SQLite
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt

  // Relations
  pollSuggestions PollSuggestion[]
  teamRestaurants TeamRestaurant[]
  pollsWon        Poll[]           @relation("PollWinner")
  reviews         Review[]

  @@unique([provider, providerId])
  @@map("restaurants")
}

model Poll {
  id              String      @id @default(cuid())
  teamId          String
  status          String      @default("ACTIVE")  // ACTIVE or CLOSED
  closeTime       DateTime?
  constraintsJson String?   // JSON as string for SQLite
  winnerRestaurantId String?
  randomSeed      String?     // For consistent tie-breaking
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  team            Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  suggestions     PollSuggestion[]
  votes           PollVote[]
  winner          Restaurant?         @relation("PollWinner", fields: [winnerRestaurantId], references: [id])
  reviews         Review[]

  @@map("polls")
}

model PollSuggestion {
  pollId       String
  restaurantId String
  suggestedBy  String
  suggestedAt  DateTime @default(now())

  // Relations
  poll         Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [suggestedBy], references: [id], onDelete: Cascade)

  @@id([pollId, restaurantId])
  @@map("poll_suggestions")
}

model PollVote {
  pollId       String
  userId       String
  restaurantId String
  votedAt      DateTime @default(now())

  // Relations
  poll         Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([pollId, userId, restaurantId])
  @@map("poll_votes")
}

model TeamRestaurant {
  teamId        String
  restaurantId  String
  lastVisitedAt DateTime?
  timesVisited  Int       @default(0)

  // Relations
  team          Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@id([teamId, restaurantId])
  @@map("team_restaurants")
}

model Review {
  pollId       String
  restaurantId String
  userId       String
  rating       Int       // 1-5 stars
  comment      String?
  createdAt    DateTime  @default(now())

  // Relations
  poll         Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([pollId, restaurantId, userId])
  @@map("reviews")
}

// SQLite schema - simplified for development
// Note: Arrays, JSON, and enums stored as strings